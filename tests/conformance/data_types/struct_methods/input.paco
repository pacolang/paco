struct Point {
    x: int,
    y: int,

    fn new(x: int, y: int) -> Point {
        Point { x: x, y: y }
    }

    fn get_x(self&) -> int {
        self.x
    }

    fn get_y(self&) -> int {
        self.y
    }

    fn add(self&, other: &Point) -> Point {
        Point { x: self.x + other.x, y: self.y + other.y }
    }
}

fn main() {
    let p1 = Point::new(10, 20)
    let p2 = Point::new(30, 40)
    let p3 = p1.add(&p2)
    print(p3.get_x())
    print(p3.get_y())
}
